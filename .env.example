# Crate environment configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains real secrets.
#
# How to get each key:
#   ANTHROPIC_API_KEY  — https://console.anthropic.com/
#   ACOUSTID_API_KEY   — https://acoustid.org/api-key (free)
#   DISCOGS_TOKEN      — https://www.discogs.com/settings/developers
#   MUSICBRAINZ_APP    — no registration needed, just set a User-Agent string
# ============================================================

# --- Required: AI crate fill ---
ANTHROPIC_API_KEY=your_key_here

# --- Required: track identification ---
ACOUSTID_API_KEY=your_key_here

# --- Optional: metadata enrichment ---
# MusicBrainz does not require a key, but does require a User-Agent.
# Format: "AppName/version (contact@email.com)"
MUSICBRAINZ_APP=CrateApp/0.1 (your@email.com)

# Discogs is optional but improves label/catalogue data for electronic music.
DISCOGS_TOKEN=your_token_here

# --- Phase 2: Spotify integration (leave blank until Phase 5) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Paths ---
# Path to the SQLite database file. Relative to the project root.
DB_PATH=./crate.db

# Absolute path to your music folder. This is the folder Crate watches for new tracks.
# Example: /Users/yourname/Music/DJ Library
MUSIC_FOLDER=/absolute/path/to/your/music

# --- Development ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
